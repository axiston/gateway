---
import { Icon } from "astro-icon/components";

export interface Props {
	icon: string;
	hint: string;
	href?: string;
}

const { icon, hint, href = "#" } = Astro.props;
---
<a href={href} class="h-16 w-16 ease-in-out duration-100 bg-gray-100 hover:bg-gray-200 flex justify-center items-center relative group">
    <Icon class="h-6 w-6" name={icon} />

    <span role="tooltip" class="absolute left-full ml-2 hidden group-hover:opacity-100 group-hover:block whitespace-nowrap px-1.5 py-1 text-sm text-white bg-gray-800 rounded-sm opacity-0 transition-opacity">
        <!-- Little arrow pointing to the left. -->
        <span class="absolute -left-1 top-1/2 -translate-y-1/2 w-2 h-2 bg-gray-800 rotate-45"/>
        {hint}
    </span>
</a>
