---
import { SERVICE_NAME } from "@/const.config.ts";

const currentYear = new Date().getFullYear();
const copyright = `© ${currentYear} ${SERVICE_NAME}. All Rights Reserved.`;
---
<footer class="bg-black/5">
    <div class="w-full container mx-auto">
        <div class="flex justify-between py-4">

            <!-- Left side -->
            <div class="text-sm">
                <a href="/" class="ease-in-out duration-100 text-gray-500 hover:text-gray-600">
                    {copyright}
                </a>
            </div>

            <!-- Right side -->
            <div class="flex gap-2 text-sm">
                <a href="#" class="ease-in-out duration-100 text-gray-500 hover:text-gray-600">
                    Privacy Policy
                </a>
                <a href="#" class="ease-in-out duration-100 text-gray-500 hover:text-gray-600">
                    Terms of Service
                </a>
            </div>

        </div>
    </div>
</footer>
