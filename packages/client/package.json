{
	"name": "@axiston/client",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:cov": "vitest run --coverage",
		"bench": "vitest bench",
		"bench:watch": "vitest bench -w",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check --apply .",
		"ci": "biome ci ."
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@vitest/coverage-istanbul": "^2.1.4",
		"tsup": "^8.3.5",
		"typescript": "^5.6.3",
		"vitest": "^2.1.3"
	}
}
